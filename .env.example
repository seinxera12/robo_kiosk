# =============================================================================
# Voice Kiosk Chatbot Configuration
# =============================================================================
# Copy this file to .env and customize values for your deployment

# =============================================================================
# Docker Compose Configuration
# =============================================================================

# Hugging Face token for model downloads (optional)
HUGGING_FACE_HUB_TOKEN=your-hf-token-here

# SearXNG secret key (change in production)
SEARXNG_SECRET=changeme-random-secret-key

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# =============================================================================
# Server Configuration
# =============================================================================

# Server host and port
SERVER_HOST=0.0.0.0
SERVER_PORT=8765

# =============================================================================
# LLM Backend Configuration
# =============================================================================

# vLLM (Primary LLM Backend)
# Note: Use service name 'vllm' when running in Docker Compose
VLLM_BASE_URL=http://vllm:8001/v1
VLLM_MODEL_NAME=Qwen/Qwen2.5-7B-Instruct-AWQ

# Ollama (Secondary LLM Backend)
# Note: Use service name 'ollama' when running in Docker Compose
OLLAMA_BASE_URL=http://ollama:11434/v1
OLLAMA_MODEL_NAME=qwen2.5:7b-instruct

# Grok API (Tertiary LLM Backend - Cloud Fallback)
# WARNING: Using Grok API sends data outside your local network
GROK_API_KEY=your-grok-api-key-here

# =============================================================================
# Speech-to-Text (STT) Configuration
# =============================================================================

# Whisper model: tiny, base, small, medium, large-v2, large-v3, large-v3-turbo
STT_MODEL=large-v3-turbo

# Compute type: float16 (GPU ≥12GB), int8 (GPU <12GB), int8_float16
STT_COMPUTE_TYPE=float16

# =============================================================================
# Text-to-Speech (TTS) Configuration
# =============================================================================

# English TTS engine: cosyvoice2
TTS_EN_ENGINE=cosyvoice

# CosyVoice2 TTS service URL (fallback for English when Kokoro is unavailable)
COSYVOICE_URL=http://localhost:5002

# ---------------------------------------------------------------------------
# Kokoro-82M TTS (English primary engine — runs locally, no service needed)
# ---------------------------------------------------------------------------

# Voice name — see https://huggingface.co/hexgrad/Kokoro-82M for full list
# American female voices: af_heart (default), af_bella, af_nicole, af_sarah, af_sky
# American male voices:   am_adam, am_michael
# British female voices:  bf_emma, bf_isabella
# British male voices:    bm_george, bm_lewis
KOKORO_VOICE=af_heart

# Speech rate multiplier (0.5 = half speed, 1.0 = normal, 1.5 = 50% faster)
KOKORO_SPEED=1.0

# Device for Kokoro inference: "cpu" (default, works everywhere) or "cuda"
KOKORO_DEVICE=cpu

# Language variant: "a" = American English, "b" = British English
KOKORO_LANG=a

# ---------------------------------------------------------------------------
# KokoClone Japanese TTS (zero-shot voice cloning — runs as separate service)
# ---------------------------------------------------------------------------

# KokoClone is NOT a pip package. It runs as a microservice in its own Python 3.12 venv.
# Setup (one-time):
#   git clone https://github.com/Ashish-Patnaik/kokoclone.git kokoclone
#   cd kokoclone && uv sync        # CPU
#   cd kokoclone && uv sync --extra gpu  # GPU (Nvidia)
# Start the service:
#   cd kokoclone && source .venv/bin/activate && python server.py

# URL of the running KokoClone microservice (default port 5003)
KOKOCLONE_URL=http://localhost:5003

# Path to a reference WAV file (3–10 seconds) for voice cloning.
# Leave blank to disable KokoCloneTTS and fall back to KokoroJapaneseTTS.
KOKOCLONE_REF_AUDIO=/home/seinxera12/robotic_robo/voices_reference/reference_ja.wav

# Enable or disable the KokoClone engine (true/false/0/1/yes/no). Default: true.
KOKOCLONE_ENABLED=true

# =============================================================================
# RAG (Retrieval-Augmented Generation) Configuration
# =============================================================================

# Toggle RAG retrieval on/off (true/false). Set to false to skip ChromaDB
# lookups entirely — useful for testing LLM responses without knowledge base.
USE_RAG=false

# ChromaDB storage path
CHROMADB_PATH=/chroma

# Building name for context
BUILDING_NAME=Office Building

# =============================================================================
# Web Search Configuration
# =============================================================================

# SearXNG URL for web search tool
# Note: Use service name 'searxng' when running in Docker Compose
SEARXNG_URL=http://searxng:8080

# =============================================================================
# Client Configuration
# =============================================================================

# WebSocket URL to connect to server
# Note: Use 'localhost' when client runs on host, 'voice-server' when in Docker
SERVER_WS_URL=ws://localhost:8765/ws

# Kiosk identification
KIOSK_ID=kiosk-01
KIOSK_LOCATION=Floor 1 Lobby
