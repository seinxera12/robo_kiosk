# =============================================================================
# Voice Kiosk Chatbot — Environment Configuration
# =============================================================================
# Copy this file to .env:   cp .env.example .env
# Then edit .env with your values.
#
# TWO PROFILES ARE DOCUMENTED BELOW:
#   [6GB]  - RTX 4050 6GB / any GPU with 6GB VRAM  (current default)
#   [16GB] - RTX 3090/4090/A5000 full-spec setup
# =============================================================================

# -----------------------------------------------------------------------------
# Docker / General
# -----------------------------------------------------------------------------

# HuggingFace token — only needed if downloading gated models
HUGGING_FACE_HUB_TOKEN=

# SearXNG secret key — change this to any random string
SEARXNG_SECRET=changeme-replace-this

# Log verbosity: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------

SERVER_HOST=0.0.0.0
SERVER_PORT=8765

# -----------------------------------------------------------------------------
# LLM — vLLM (PRIMARY, disabled on 6GB)
# -----------------------------------------------------------------------------
# [6GB]  Leave as-is. vLLM is commented out in docker-compose.yml.
#        The fallback chain will skip it automatically (health check fails).
# [16GB] Set VLLM_BASE_URL=http://vllm:8001/v1 and uncomment vllm in compose.

VLLM_BASE_URL=http://localhost:8001/v1
VLLM_MODEL_NAME=Qwen/Qwen2.5-7B-Instruct-AWQ

# -----------------------------------------------------------------------------
# LLM — Ollama (PRIMARY on 6GB, secondary on 16GB)
# -----------------------------------------------------------------------------
# [6GB]  qwen2.5:3b-instruct  — ~2.5GB VRAM, fast, good bilingual quality
# [16GB] qwen2.5:7b-instruct  — ~5GB VRAM, better quality

OLLAMA_BASE_URL=http://ollama:11434/v1
OLLAMA_MODEL_NAME=qwen2.5:3b-instruct

# -----------------------------------------------------------------------------
# LLM — Grok API (cloud fallback, optional)
# -----------------------------------------------------------------------------
# Leave empty to disable. When empty, GrokBackend raises ValueError and
# the fallback chain skips it cleanly.
# WARNING: Enabling this sends conversation data to xAI's servers.

GROK_API_KEY=

# -----------------------------------------------------------------------------
# Speech-to-Text — Whisper
# -----------------------------------------------------------------------------
# STT_MODEL options: tiny | base | small | medium | large-v2 | large-v3 | large-v3-turbo
# STT_COMPUTE_TYPE:
#   float16 — full precision, needs ~3GB VRAM  → use on 12GB+ GPU
#   int8    — half VRAM (~1.5GB), minimal accuracy loss → use on 6GB GPU
#
# [6GB]  large-v3-turbo + int8   → ~1.5GB VRAM
# [16GB] large-v3-turbo + float16 → ~3GB VRAM

STT_MODEL=large-v3-turbo
STT_COMPUTE_TYPE=int8

# -----------------------------------------------------------------------------
# Text-to-Speech
# -----------------------------------------------------------------------------
# English TTS: cosyvoice (placeholder — yields silence until CosyVoice installed)
# Japanese TTS: VOICEVOX via Docker REST API (CPU, no VRAM)

TTS_EN_ENGINE=cosyvoice
TTS_JP_URL=http://voicevox:50021
# CosyVoice2 model — HuggingFace repo ID or local path inside the container
# Set to a local path like /models/CosyVoice2-0.5B if you've downloaded it
COSYVOICE_MODEL_PATH=iic/CosyVoice2-0.5B
# Device for CosyVoice2: cuda | cpu
COSYVOICE_DEVICE=cuda

# -----------------------------------------------------------------------------
# RAG — ChromaDB
# -----------------------------------------------------------------------------

CHROMADB_PATH=/chroma
BUILDING_NAME=Office Building

# -----------------------------------------------------------------------------
# Web Search — SearXNG
# -----------------------------------------------------------------------------
# Internal Docker network URL — always port 8080 inside the network
# regardless of what host port you map in docker-compose.yml

SEARXNG_URL=http://searxng:8080

# -----------------------------------------------------------------------------
# Client
# -----------------------------------------------------------------------------

SERVER_WS_URL=ws://localhost:8765/ws
KIOSK_ID=kiosk-01
KIOSK_LOCATION=Floor 1 Lobby
